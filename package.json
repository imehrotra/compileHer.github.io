{
  "name": "compileher-website",
  "version": "1.0.0",
  "description": "CompileHer website with testing infrastructure",
  "main": "index.html",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/tests/**/*.test.js",
      "**/tests/**/*.spec.js"
    ],
    "collectCoverageFrom": [
      "js/**/*.js",
      "!js/vendor/**",
      "!js/**/*.min.js"
    ]
  }
}